@{
    ViewData["Title"] = "Edit Blog";
}

<h1>Edit Blog</h1>

<input type="hidden" id="txtId" value="@ViewBag.BlogId" />

<div class="mb-3">
    <label class="form-label">Title</label>
    <input type="text" class="form-control" id="txtTitle">
</div>
<div class="mb-3">
    <label class="form-label">Author</label>
    <input type="text" class="form-control" id="txtAuthor">
</div>
<div class="mb-3">
    <label class="form-label">Content</label>
    <textarea class="form-control" id="txtContent" rows="3"></textarea>
</div>
<a href="/BlogAjax/Index" class="btn btn-secondary">Cancel</a>
<button type="button" class="btn btn-primary" id="btnUpdate">Update</button>

@section scripts {
    <script>
        $(document).ready(function () {
            const blogId = $('#txtId').val();

            // 1. Page တက်လာတာနဲ့ ရှိပြီးသား Data တွေကို standard textbox တွေထဲ ဖြည့်ပေးခြင်း
            $.ajax({
                url: `/BlogAjax/GetBlog/${blogId}`,
                type: "GET",
                success: function (response) {
                    if (response.Data) {
                        $('#txtTitle').val(response.Data.Title);
                        $('#txtAuthor').val(response.Data.Author);
                        $('#txtContent').val(response.Data.Content);
                    } else {
                        alert(response.Message);
                    }
                },
                error: function (xhr) {
                    console.error(xhr.responseText);
                }
            });

            // 2. Update Button နှိပ်လိုက်ရင် အချက်အလက်သစ်တွေကို သိမ်းဆည်းခြင်း
            $('#btnUpdate').click(function () {
                const blogData = {
                    Id: $('#txtId').val(),
                    Title: $('#txtTitle').val(),
                    Author: $('#txtAuthor').val(),
                    Content: $('#txtContent').val()
                };

                $.ajax({
                    url: "/BlogAjax/Update",
                    type: "POST",
                    data: { requestModel: blogData },
                    success: function (response) {
                        alert(response.Message);
                        if (response.IsSuccess) {
                            window.location.href = "/BlogAjax/Index";
                        }
                    },
                    error: function (xhr) {
                        console.error(xhr.responseText);
                    }
                });
            });
        });
    </script>
}