@model PaginationModel
@{
    int pageNo = Model.PageNo;
    int pageSize = Model.PageSize;
    int pageCount = Model.PageCount;
}

<nav aria-label="...">
    <ul class="pagination">
        @if (pageNo == 1)
        {
            <li class="page-item disabled">
                <a class="page-link">Previous</a>
            </li>
        }
        else
        {
            <li class="page-item">
                <a class="page-link"
                   href="/Blog/Index?pageNo=@(pageNo - 1)&pageSize=@(Model.PageSize)">
                    Previous
                </a>
            </li>
        }

        @if (pageNo > 3 && pageNo < pageCount - 2)
        {
            <li class="page-item">
                <a class="page-link"
                   href="/Blog/Index?pageNo=@(1)&pageSize=@(Model.PageSize)">@(1)</a>
            </li>

            <li class="page-item disabled">
                <a class="page-link">...</a>
            </li>

            @for (int i = pageNo - 2; i <= pageNo + 2; i++)
            {
                if (Model.PageNo == i)
                {
                    <li class="page-item active">
                        <a class="page-link" href="/Blog/Index?pageNo=@(i)&pageSize=@(Model.PageSize)"
                           aria-current="page">@i</a>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link"
                           href="/Blog/Index?pageNo=@(i)&pageSize=@(Model.PageSize)">@(i)</a>
                    </li>
                }
            }

            <li class="page-item disabled">
                <a class="page-link">...</a>
            </li>

            <li class="page-item">
                <a class="page-link"
                   href="/Blog/Index?pageNo=@(pageCount)&pageSize=@(Model.PageSize)">@(pageCount)</a>
            </li>
        }
        else
        {
            @* 1 2 3... 8 9 10 *@

            @for (int i = 1; i <= 4; i++)
            {
                if (Model.PageNo == i)
                {
                    <li class="page-item active">
                        <a class="page-link" href="/Blog/Index?pageNo=@(i)&pageSize=@(Model.PageSize)"
                           aria-current="page">@i</a>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link"
                           href="/Blog/Index?pageNo=@(i)&pageSize=@(Model.PageSize)">@(i)</a>
                    </li>
                }
            }

            <li class="page-item disabled">
                <a class="page-link">...</a>
            </li>

            @for (int i = pageCount - 3; i <= pageCount; i++)
            {
                if (Model.PageNo == i)
                {
                    <li class="page-item active">
                        <a class="page-link" href="/Blog/Index?pageNo=@(i)&pageSize=@(Model.PageSize)"
                           aria-current="page">@i</a>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link"
                           href="/Blog/Index?pageNo=@(i)&pageSize=@(Model.PageSize)">@(i)</a>
                    </li>
                }
            }
        }

        @if (pageNo == pageCount)
        {
            <li class="page-item disabled">
                <a class="page-link">Next</a>
            </li>
        }
        else
        {
            <li class="page-item">
                <a class="page-link"
                   href="/Blog/Index?pageNo=@(pageNo + 1)&pageSize=@(Model.PageSize)">
                    Next
                </a>
            </li>
        }
    </ul>
</nav>