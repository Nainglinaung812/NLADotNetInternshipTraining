@model BlogEditResponseModel

<div class="container mt-5">
    <div class="card border-danger">
        <div class="card-header bg-danger text-white">
            <h4>Delete Confirmation</h4>
        </div>
        <div class="card-body">
            <h5 class="text-danger">Are you sure you want to delete this blog?</h5>
            <hr />
            <dl class="row">
                <dt class="col-sm-2">Title</dt>
                <dd class="col-sm-10">@Model.Data.Title</dd>

                <dt class="col-sm-2">Author</dt>
                <dd class="col-sm-10">@Model.Data.Author</dd>
                
                <dt class="col-sm-2">Content</dt>
                <dd class="col-sm-10">@Model.Data.Content</dd>
            </dl>

            <form action="/Blog/DeleteConfirm" method="post" class="mt-4">
                <input type="hidden" name="id" value="@Model.Data.Id" />
                
                <button type="submit" class="btn btn-danger px-4 me-2">Yes, Delete</button>
                
                <a href="/blog" class="btn btn-secondary px-4">No, Go Back</a>
            </form>
        </div>
    </div>
</div>