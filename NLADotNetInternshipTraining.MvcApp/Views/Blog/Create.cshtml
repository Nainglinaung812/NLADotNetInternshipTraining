<form action="/blog/save" method="post">
    <div class="mb-3">
        <label for="txtTitle" class="form-label">Title</label>
        <input type="text" class="form-control" name="Title" id="txtTitle" placeholder="Enter title">
    </div>

    <div class="mb-3">
        <label for="txtAuthor" class="form-label">Author</label>
        <input type="text" class="form-control" name="Author" id="txtAuthor" placeholder="Enter author name">
    </div>

    <div class="mb-3">
        <label for="txtContent" class="form-label">Content</label>
        <textarea class="form-control" name="Content" id="txtContent" rows="5" placeholder="Enter content"></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Submit</button>
</form>