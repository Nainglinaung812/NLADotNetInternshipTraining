@model BlogListResponseModel
@{
    int count = (Model.PageNo - 1) * Model.PageSize;

    int pageNo = Model.PageNo;
    int pageSize = Model.PageSize;
    int pageCount = Model.PageCount;
}

<a href="/blog/create" class="btn btn-primary mb-3">Create New Blog</a>

<table class="table table-bordered table-responsive">
    <thead>
        <tr>
            <th>
                Actions
            </th>
            <th>
                No.
            </th>
            <th>
                Title
            </th>
            <th>
                Author
            </th>
            <th>
                Content
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var blog in Model.Data)
        {
            <tr>
                <td>
                    <a href="/blog/edit?Id=@blog.Id" class="btn btn-outline-warning">
                        Edit
                    </a>
                    <a href="/blog/delete?Id=@blog.Id" class="btn btn-outline-danger">
                        Delete
                    </a>
                </td>
                <td>
                    @(++count)
                </td>
                <td>
                    @blog.Title
                </td>
                <td>
                    @blog.Author
                </td>
                <td>
                    @blog.Content
                </td>
            </tr>
        }
    </tbody>
</table>

@await Html.PartialAsync("_Pagination", new PaginationModel
{
    PageNo = Model.PageNo,
    PageSize = Model.PageSize,
    PageCount = Model.PageCount
})

@*
1 2 3 ... 8 9 10
1 ... 6 7 8 ... 10

1000

1 2 3 ... 1000 - 2 = 998 999 1000

pageNo > 3 && pageNo < pageCount - 2

1 ... 5 6 7 8 9 ... 10

@for (int i = 1; i <= Model.PageCount; i++)
{
    if (Model.PageNo == i)
    {
        <li class="page-item active">
            <a class="page-link" href="/Blog/Index?pageNo=@(i)&pageSize=@(Model.PageSize)"
                aria-current="page">@i</a>
        </li>
    }
    else
    {
        <li class="page-item">
            <a class="page-link"
                href="/Blog/Index?pageNo=@(i)&pageSize=@(Model.PageSize)">@(i)</a>
        </li>
    }
}
