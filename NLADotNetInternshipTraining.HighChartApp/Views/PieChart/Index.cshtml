        //     },
        //     {
        //         name: 'Others',
        //         y: 22000
        //     }
        // ];

        let _data = @Html.Raw(Json.Serialize(Model));

        Highcharts.chart('chart-container', {
            chart: {
                type: 'pie',
                zooming: {
                    type: 'xy'
                },
                panning: {
                    enabled: true,
                    type: 'xy'
                },
                panKey: 'shift'
            },
            title: {
                text: 'Sales Revenue by Category'
            },
            subtitle: {
                text: 'Current Month Sales Distribution'
            },
            tooltip: {
                pointFormat: '<b>${point.y:,.0f}</b><br/>({point.percentage:.1f}%)'
            },
            plotOptions: {
                pie: {
                    allowPointSelect: true,
                    cursor: 'pointer',
                    dataLabels: [{
                        enabled: true,
                        format: '{point.name}'
                    }, {
                        enabled: true,
                        distance: -40,
                        format: '{point.percentage:.1f}%',
                        style: {
                            fontSize: '1.2em',
                            textOutline: 'none',
                            opacity: 0.7
                        },
                        filter: {
                            property: 'percentage',
                            operator: '>',
                            value: 5
                        }
                    }]
                }
            },
            series: [{
                name: 'Sales',
                colorByPoint: true,
                data: _data
            }]
        });
    </script>
}